# ══════════════════════════════════════════════════════════════════
#  Arbitrage System — Environment Variables
#  Copy to .env and fill in your credentials before running.
# ══════════════════════════════════════════════════════════════════

DEPLOY_MODE=shared

# ── Infrastructure ────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=arbredis

POSTGRES_PASSWORD=arb
POSTGRES_DSN=postgresql://arb:arb@127.0.0.1:5432/arb

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_COLLECTION=markets

# ── Kalshi Credentials ────────────────────────────────────────────
# API key ID from https://kalshi.com/account/api
KALSHI_API_KEY_ID=

# RSA private key in PEM format with newlines replaced by \n
# Example: -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
KALSHI_PRIVATE_KEY_PEM=

KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_URL=wss://api.elections.kalshi.com/trade-api/ws/v2

# ── Polymarket Credentials ────────────────────────────────────────
# Ethereum wallet private key (0x-prefixed)
POLY_PRIVATE_KEY=0x...

# CLOB API credentials from https://polymarket.com/profile
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

POLY_CLOB_HOST=https://clob.polymarket.com
POLY_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLY_CHAIN_ID=137

# ── Strategy Parameters ───────────────────────────────────────────
# Minimum gross edge to consider a trade (fraction: 0.03 = 3%)
MIN_EDGE=0.03

# Estimated total round-trip fee (fraction: 0.02 = 2%)
FEE_ESTIMATE=0.02

# Max contracts per single trade
MAX_TRADE_SIZE=100.0

# Max contracts held per market
MAX_POSITION_PER_MARKET=500.0

# Min orderbook size required on each side to proceed
MIN_LIQUIDITY=10.0

# Max total portfolio notional (USD)
MAX_PORTFOLIO_NOTIONAL=10000.0

# ── Resolver Parameters ───────────────────────────────────────────
# Cosine similarity threshold for market matching (0.85 = very confident)
MATCH_THRESHOLD=0.85
EMBED_MODEL=all-MiniLM-L6-v2
# Embedding execution device: auto | cuda | cpu
EMBED_DEVICE=auto
# Run startup cache backfill so resolver can recover matches after restarts
RESOLVER_BACKFILL_ON_STARTUP=true
# Startup backfill embedding batch size (larger values usually favor GPU throughput)
RESOLVER_BACKFILL_EMBED_BATCH_SIZE=64
# Periodic cleanup cadence for expired/stale markets and pair cache (seconds)
RESOLVER_CLEANUP_INTERVAL_SECS=300
# Grace period before treating end_date markets as expired (seconds)
RESOLVER_EXPIRED_GRACE_SECS=0
# Resolver image build options for torch wheel
RESOLVER_TORCH_VERSION=2.5.1
RESOLVER_TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
# Optional GPU override wheel index (used by docker-compose.gpu.yml)
RESOLVER_TORCH_INDEX_URL_GPU=https://download.pytorch.org/whl/cu124

# ── LLM Routing ───────────────────────────────────────────────────
LLM_BASE_URL=http://127.0.0.1:8000/v1

# ── Executor Parameters ───────────────────────────────────────────
# Cancel order after this many seconds if unfilled
ORDER_TIMEOUT_SECS=30.0
ORDER_POLL_INTERVAL=1.0
